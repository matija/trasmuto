{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trasmuto",
  "version": "0.1.0",
  "identifier": "com.trasmuto.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trasmuto",
        "width": 600,
        "height": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "fileAssociations": [
      {
        "name": "Video File",
        "description": "Video file for conversion",
        "ext": ["mp4", "mkv", "mov", "avi", "webm", "m4v", "flv", "wmv", "ts", "mts", "m2ts"],
        "role": "Editor"
      }
    ]
  }
}
